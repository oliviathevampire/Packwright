{
  "schemaVersion": 1,
  "id": "packwright",
  "version": "${version}",
  "name": "Packwright",
  "description": "Build data packs and resource packs at runtime - assets, loot, recipes, registries and full worldgen, no JSON files required. A heavily rewritten fork of ARRP.",
  "authors": [
    "OliviaTheVampire", "HalfOf2"
  ],
  "contact": {
    "homepage": "https://github.com/oliviathevampire/Packwright#readme",
    "issues": "https://github.com/oliviathevampire/Packwright/issues",
    "sources": "https://github.com/oliviathevampire/Packwright"
  },
  "license": "MPLv2",
  "icon": "assets/packwright/icon.png",
  "environment": "*",
  "entrypoints": {
    "preLaunch": ["net.vampirestudios.packwright.Packwright"]
  },
  "mixins": [
    "packwright.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": ">=26.1.2 <26.3-"
  },
  "custom": {
    "modmenu": {
      "badges": [ "library" ]
    }
  }
}
